{
    "host": "0.0.0.0",
    "port": 443,
    "log_level": "info",
    "json_log_enable": true,
    "namespace": "tesla_telemetry",
    "reliable_ack": false,
    "monitoring": {
        "prometheus_metrics_port": 9090,
        "profiler_port": 4269,
        "profiling_path": "/tmp/trace.out",
        "otel": {
            "endpoint": "localhost:4317",
            "service_name": "fleet-telemetry",
            "protocol": "grpc",
            "insecure": true,
            "logging": true,
            "tracing": true,
            "trace_sample_rate": 1.0
        }
    },
    "rate_limit": {
        "enabled": true,
        "message_interval_time": 30,
        "message_limit": 1000
    },
    "records": {
        "alerts": [
            "logger"
        ],
        "errors": [
            "logger"
        ],
        "V": [
            "logger"
        ],
        "connectivity": [
            "logger"
        ]
    },
    "tls": {
        "server_cert": "/etc/certs/server/tls.crt",
        "server_key": "/etc/certs/server/tls.key"
    }
}
